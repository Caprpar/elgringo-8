pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
function _init()
	sprite=1
	stimer=0
	player={
		x=10,
		y=100,
		speed=1,
	}
end

function _update()
 if stimer<10 then
  stimer+=1
  else
   if sprite<7 then 
 	 sprite+=2
   else 
 	 sprite=1 
   end
   stimer=0
 end
end

function _draw()
cls()
 spr(sprite,56,56,2,2)
end
